services:
    dev:
        image: sail-lite/basic
        build:
            context: ./vendor/reedware/sail-lite/runtimes/basic
            dockerfile: Dockerfile
            args:
                PHP: '${PHP_VERSION:-8.5}'
                WWWGROUP: '${WWWGROUP}'
        environment:
            WWWUSER: '${WWWUSER}'
        volumes:
            - '.:/var/www/html'
